{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@cloudflare/workers-types": "^4.20251213.0",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "goey-toast": "^0.4.0",
      "@trpc/server": "^11.13.4",
      "@trpc/client": "^11.13.4",
      "better-auth": "1.5.5",
      "@opennextjs/cloudflare": "^1.17.3",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "alchemy": "^0.90.0",
      "drizzle-orm": "^0.45.1",
      "stripe": "^22.0.1",
      "@opentelemetry/api": "^1.9.0",
      "@opentelemetry/sdk-node": "^0.55.0",
      "@opentelemetry/instrumentation-http": "^0.55.0",
      "@opentelemetry/instrumentation-fetch": "^0.55.0",
      "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
      "@opentelemetry/resources": "^1.28.0",
      "@opentelemetry/semantic-conventions": "^1.28.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev:bare",
    "db:push": "turbo -F @my-better-t-app/db db:push",
    "db:studio": "turbo -F @my-better-t-app/db db:studio",
    "db:generate": "turbo -F @my-better-t-app/db db:generate",
    "db:migrate": "turbo -F @my-better-t-app/db db:migrate",
    "deploy": "turbo -F @my-better-t-app/infra deploy",
    "destroy": "turbo -F @my-better-t-app/infra destroy",
    "format": "prettier --write .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@my-better-t-app/env": "workspace:*",
    "@trpc/server": "catalog:",
    "ai": "^6.0.146",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "framer-motion": "^12.38.0",
    "goey-toast": "^0.4.0",
    "next": "catalog:",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@lhci/cli": "^0.15.1",
    "@my-better-t-app/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.14",
    "bun-types": "^1.3.14",
    "lefthook": "latest",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.10.2",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.6",
  "patchedDependencies": {
    "proper-lockfile@4.1.2": "patches/proper-lockfile@4.1.2.patch"
  }
}
