# Database
# Required for persistent storage. Use a PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?sslmode=require"

# Authentication (Better-Auth)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your_better_auth_secret_here"
BETTER_AUTH_URL="http://localhost:3001"

# OAuth Providers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# AI Integration (OpenRouter)
OPENROUTER_API_KEY="your_openrouter_api_key"

# Email Service (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="notifications@yourdomain.com"

# Storage (UploadThing)
UPLOADTHING_TOKEN="your_uploadthing_token"

# Error Tracking & Monitoring (Sentry)
SENTRY_DSN="https://your_sentry_dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your_sentry_dsn"
SENTRY_AUTH_TOKEN="your_sentry_auth_token"
SENTRY_ORG="your_sentry_org"
SENTRY_PROJECT="your_sentry_project"

# Performance & Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Infrastructure & Deployment
CORS_ORIGIN="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
CRON_SECRET="your_cron_secret_for_scheduled_tasks"

# Observability (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Plan Price IDs
STRIPE_PLAN_1_PRICE_ID="price_..."
STRIPE_PLAN_2_PRICE_ID="price_..."
STRIPE_LTD_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PLAN_1_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PLAN_2_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_LTD_PRICE_ID="price_..."
STRIPE_PLAN_1_YEARLY_PRICE_ID="price_..."
STRIPE_PLAN_2_YEARLY_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PLAN_1_YEARLY_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PLAN_2_YEARLY_PRICE_ID="price_..."